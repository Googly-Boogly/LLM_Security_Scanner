# ── Target LLM ────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic          # anthropic | openai | google
LLM_MODEL=claude-haiku-4-5-20251001
LLM_API_KEY=your-api-key-here

# ── Judge LLM ─────────────────────────────────────────────────────────────────
# Evaluates whether attacks succeeded. Defaults to LLM_MODEL if left empty.
# Use a cheaper/faster model to reduce cost.
JUDGE_MODEL=claude-haiku-4-5-20251001

# ── Scan behaviour ────────────────────────────────────────────────────────────
# System prompt sent to the target for probes that don't override it.
SYSTEM_PROMPT=You are a helpful assistant.

# Comma-separated categories: injection, jailbreak, leakage, harmful
CATEGORIES=injection,jailbreak,leakage,harmful

# Max simultaneous API calls
CONCURRENCY=5

# ── Output ────────────────────────────────────────────────────────────────────
# Leave empty to auto-generate: scan_YYYYMMDD_HHMMSS.json
OUTPUT=
